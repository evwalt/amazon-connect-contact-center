{
  "name": "amazon-connect-contact-center",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest tests/unit --coverage",
    "test:integration": "jest tests/integration",
    "build": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.4",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/index.ts"
    ]
  }
}
