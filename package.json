{
  "name": "amazon-connect-contact-center",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest tests/unit --coverage",
    "test:integration": "jest tests/integration",
    "build": "tsc --noEmit",
    "build:sam": "PATH=\"$PWD/node_modules/.bin:$PATH\" sam build --template-file infrastructure/template.yaml",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.28.1",
    "jest": "^29.7.0",
    "prettier": "^3.8.4",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/index.ts"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1071.0",
    "@aws-sdk/lib-dynamodb": "^3.1071.0"
  }
}
